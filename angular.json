{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "tensorboard-webapp": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "tensorboard/webapp",
      "prefix": "tb",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/tensorboard-webapp",
            "index": "tensorboard/webapp/index_polymer3.uninlined.html",
            "main": "tensorboard/webapp/main_prod.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.json",
            "assets": [],
            "styles": [],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [],
              "outputHashing": "none"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "browserTarget": "tensorboard-webapp:build:production" },
            "development": { "browserTarget": "tensorboard-webapp:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "tsconfig.json",
            "polyfills": ["zone.js", "zone.js/testing"],
            "karmaConfig": "karma.conf.js"
          }
        }
      }
    }
  },
  "defaultProject": "tensorboard-webapp"
}
